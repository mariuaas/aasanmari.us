---
import "../styles/global.css";

type Props = {
    title: string;
    description?: string;
};

const { title, description } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        {description ? <meta name="description" content={description} /> : null}

        <link rel="icon" type="image/png" sizes="128x128" href="/icon_128.png" />
        <link rel="shortcut icon" href="/icon_128.png" />

        <script is:inline>
            (() => {
                try {
                    const stored = localStorage.getItem('theme');
                    const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                    const theme = stored === 'light' || stored === 'dark' ? stored : (prefersDark ? 'dark' : 'light');
                    document.documentElement.dataset.theme = theme;
                } catch {
                    // ignore
                }
            })();
        </script>

        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
            referrerpolicy="no-referrer"
        />

        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
            integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
            crossorigin="anonymous"
        />

    </head>
    <body class="min-h-screen bg text-(--fg)">
        <header class="border-b theme-border">
            <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
                <a href="/" class="font-heading text-lg font-normal tracking-wide theme-fg">aasanmari.us</a>
                <div class="flex items-center gap-4 text-base">
                    <a class="theme-muted theme-hover-fg" href="/">Home</a>
                    <a class="theme-muted theme-hover-fg" href="/papers">Papers</a>
                    <a class="theme-muted theme-hover-fg" href="/cv">CV</a>
                    <button
                        id="theme-toggle"
                        type="button"
                        class="ml-1 rounded-md px-2 py-1 theme-muted theme-hover-fg theme-hover-panel"
                        aria-label="Toggle theme"
                        title="Toggle theme"
                    >
                        <i class="fa-solid fa-circle-half-stroke"></i>
                    </button>
                </div>
            </nav>
        </header>

        <!-- Sidebar + content -->
        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-10 px-6 py-4 md:grid-cols-[9rem_1fr]">
            <aside class="md:sticky md:top-6 h-fit rounded-xl border theme-border theme-panel p-4">
                <div class="flex justify-center gap-3">
                    <p><a href="/">
                    <img
                        src="/profile2026_square.jpg"
                        alt="Marius Aasan"
                        class="h-32 w-24 rounded-full object-cover"
                        loading="lazy"
                    />
                    </a></p>
                </div>

                <nav class="mt-5">
                    <div class="mt-3 flex flex-col gap-3">

                        <a
                            class="flex items-center justify-center rounded-lg py-2 theme-muted theme-hover-fg theme-hover-panel"
                            href="https://github.com/mariuaas"
                            target="_blank"
                            rel="noreferrer"
                            aria-label="GitHub"
                            title="GitHub"
                        >
                            <i class="fa-brands fa-github text-4xl"></i>
                        </a>

                        <a
                            class="flex items-center justify-center rounded-lg py-2 theme-muted theme-hover-fg theme-hover-panel"
                            href="https://scholar.google.com/citations?user=i9mjbNcAAAAJ"
                            target="_blank"
                            rel="noreferrer"
                            aria-label="Google Scholar"
                            title="Google Scholar"
                        >
                            <i class="fa-brands fa-google-scholar text-4xl"></i>
                        </a>

                        <a
                            class="flex items-center justify-center rounded-lg py-2 theme-muted theme-hover-fg theme-hover-panel"
                            href="https://orcid.org/0000-0003-2353-9984"
                            target="_blank"
                            rel="noreferrer"
                            aria-label="ORCID"
                            title="ORCID"
                        >
                            <i class="fa-brands fa-orcid text-4xl"></i>
                        </a>

                        <a
                            class="flex items-center justify-center rounded-lg py-2 theme-muted theme-hover-fg theme-hover-panel"
                            href="https://www.linkedin.com/in/marius-aasan-19ab3162/"
                            target="_blank"
                            rel="noreferrer"
                            aria-label="LinkedIn"
                            title="LinkedIn"
                        >
                            <i class="fa-brands fa-linkedin text-4xl"></i>
                        </a>

                    </div>
                </nav>
            </aside>

            <main class="min-w-0">
                <slot />
            </main>
        </div>

        <footer class="border-t theme-border">
            <div class="mx-auto max-w-5xl px-6 py-6 text-xs theme-muted-2">
                © {new Date().getFullYear()} Marius Aasan
            </div>
        </footer>

        <script is:inline>
            (() => {
                const btn = document.getElementById('theme-toggle');
                if (!btn) return;
                btn.addEventListener('click', () => {
                    const current = document.documentElement.dataset.theme;
                    const next = current === 'light' ? 'dark' : 'light';
                    document.documentElement.dataset.theme = next;
                    try { localStorage.setItem('theme', next); } catch { /* ignore */ }
                });
            })();
        </script>
    </body>
</html>